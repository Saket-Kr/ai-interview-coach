# LLM endpoint (OpenAI-compatible API)
INTERVIEW_ANALYZER_LLM_URL=http://localhost:8040/v1
INTERVIEW_ANALYZER_LLM_API_KEY=your-api-key-here
INTERVIEW_ANALYZER_LLM_MODEL=Qwen/Qwen3-235B-A22B-FP8

# Whisper speech-to-text model (base, medium, large-v3)
WHISPER_MODEL=base
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_DEVICE=cpu

# HuggingFace token (optional — enables speaker diarization for recorded interviews)
HF_TOKEN=
